          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Validate Customer Creation" enabled="false">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper

// Parse response
def response = new JsonSlurper().parse(prev.getResponseDataAsString().getBytes())
def user = response.user

// Get response code
def statusCode = prev.getResponseCode()

// ========================
// TEST 1: Status Code 201
// ========================
if (statusCode == &quot;201&quot;) {
    log.info(&quot;✅ PASS: Customer created - Status 201&quot;)
} else {
    log.error(&quot;❌ FAIL: Expected status 201 but got &quot; + statusCode)
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Expected status 201 but got &quot; + statusCode)
}

// ================================================
// TEST 2: Response contains message and user details
// ================================================
if (response.containsKey(&quot;user&quot;) &amp;&amp; response.containsKey(&quot;message&quot;)) {
    log.info(&quot;✅ PASS: Response contains proper message and user details&quot;)
} else {
    log.error(&quot;❌ FAIL: Response missing &apos;user&apos; or &apos;message&apos; property&quot;)
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Response missing &apos;user&apos; or &apos;message&apos; property&quot;)
}

// ========================
// TEST 3: Name matches
// ========================
def expectedName = vars.get(&quot;customer_name&quot;)
if (user.name == expectedName) {
    log.info(&quot;✅ PASS: Name matches - &quot; + user.name)
} else {
    log.error(&quot;❌ FAIL: Name mismatch. Expected: &quot; + expectedName + &quot; | Got: &quot; + user.name)
}

// ========================
// TEST 4: Email matches
// ========================
def expectedEmail = vars.get(&quot;customer_email&quot;)
if (user.email == expectedEmail) {
    log.info(&quot;✅ PASS: Email matches - &quot; + user.email)
} else {
    log.error(&quot;❌ FAIL: Email mismatch. Expected: &quot; + expectedEmail + &quot; | Got: &quot; + user.email)
}

// ========================
// TEST 5: Phone matches
// ========================
def expectedPhone = vars.get(&quot;customer_phone&quot;)
if (user.phone_number == expectedPhone) {
    log.info(&quot;✅ PASS: Phone matches - &quot; + user.phone_number)
} else {
    log.error(&quot;❌ FAIL: Phone mismatch. Expected: &quot; + expectedPhone + &quot; | Got: &quot; + user.phone_number)
}

// ========================
// TEST 6: NID matches
// ========================
def expectedNid = vars.get(&quot;customer_nid&quot;)
if (user.nid == expectedNid) {
    log.info(&quot;✅ PASS: NID matches - &quot; + user.nid)
} else {
    log.error(&quot;❌ FAIL: NID mismatch. Expected: &quot; + expectedNid + &quot; | Got: &quot; + user.nid)
}

// ========================
// Store customer_id for next requests
// ========================
vars.put(&quot;customer_id&quot;, String.valueOf(user.id))
log.info(&quot;📌 customer_id saved: &quot; + user.id)</stringProp>
          </JSR223PostProcessor>
