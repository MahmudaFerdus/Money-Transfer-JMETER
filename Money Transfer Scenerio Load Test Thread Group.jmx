        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Read and Load Data from Global to Local">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">def safeLoad = { key -&gt;
    def value = props.get(key)
    if (value != null &amp;&amp; value != &quot;null&quot;) {
        vars.put(key, value)
        log.info(&quot;  ✅ Loaded: &quot; + key + &quot; = &quot; + value)
    } else {
        log.error(&quot;  ❌ MISSING: &quot; + key)
    }
}

log.info(&quot;========================================&quot;)
log.info(&quot;LOADING DATA FROM GLOBAL PROPERTIES:&quot;)

// Customer 1
log.info(&quot;CUSTOMER 1:&quot;)
safeLoad(&quot;customer_name&quot;)
safeLoad(&quot;customer_email&quot;)
safeLoad(&quot;customer_password&quot;)
safeLoad(&quot;customer_phone&quot;)
safeLoad(&quot;customer_nid&quot;)
safeLoad(&quot;customer_id&quot;)

// Customer 2 
log.info(&quot;CUSTOMER 2:&quot;)
safeLoad(&quot;customer2_name&quot;)
safeLoad(&quot;customer2_email&quot;)
safeLoad(&quot;customer2_password&quot;)
safeLoad(&quot;customer2_phone&quot;)
safeLoad(&quot;customer2_nid&quot;)
safeLoad(&quot;customer2_id&quot;)

// Agent
log.info(&quot;AGENT:&quot;)
safeLoad(&quot;agent_name&quot;)
safeLoad(&quot;agent_email&quot;)
safeLoad(&quot;agent_password&quot;)
safeLoad(&quot;agent_phone&quot;)
safeLoad(&quot;agent_nid&quot;)
safeLoad(&quot;agent_id&quot;)

// Merchant
log.info(&quot;MERCHANT:&quot;)
safeLoad(&quot;merchant_name&quot;)
safeLoad(&quot;merchant_email&quot;)
safeLoad(&quot;merchant_password&quot;)
safeLoad(&quot;merchant_phone&quot;)
safeLoad(&quot;merchant_nid&quot;)
safeLoad(&quot;merchant_id&quot;)

// Admin
log.info(&quot;ADMIN:&quot;)
safeLoad(&quot;admin_token&quot;)

log.info(&quot;========================================&quot;)</stringProp>
        </JSR223PreProcessor>
