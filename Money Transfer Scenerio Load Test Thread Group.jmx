        <hashTree>
          <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract Admin Token" enabled="true">
            <stringProp name="JSONPostProcessor.referenceNames">admin_token</stringProp>
            <stringProp name="JSONPostProcessor.jsonPathExprs">$.token</stringProp>
            <stringProp name="JSONPostProcessor.match_numbers"></stringProp>
            <stringProp name="JSONPostProcessor.defaultValues">TOKEN_NOT_FOUND</stringProp>
          </JSONPostProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Admin Login Validation" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper

// ── var res = pm.response.json() ──
def res = new JsonSlurper().parseText(prev.getResponseDataAsString())

// ── var code = pm.response.code ──
def code = prev.getResponseCode().toInteger()

// ── switch(code) ──
switch (code) {

    case 200:
        // pm.test(&quot;Status 200 - Login successful&quot;)
        log.info(&quot;✅ Status 200 - Login successful&quot;)
        
        // pm.expect(res.message).to.equal(&quot;Login successful&quot;)
        if (res.message != &quot;Login successful&quot;) {
            log.error(&quot;❌ Message mismatch: &quot; + res.message)
            prev.setSuccessful(false)
            prev.setResponseMessage(&quot;Message is not &apos;Login successful&apos;. Got: &quot; + res.message)
            return
        }
        log.info(&quot;✅ Message is &apos;Login successful&apos;&quot;)
        
        // pm.expect(res.token).to.be.ok
        if (res.token == null || res.token == &quot;&quot;) {
            log.error(&quot;❌ Token does not exist&quot;)
            prev.setSuccessful(false)
            prev.setResponseMessage(&quot;Token is missing&quot;)
            return
        }
        log.info(&quot;✅ Token exists&quot;)
        
        // pm.expect(res.role).to.equal(&quot;Admin&quot;)
        if (res.role != &quot;Admin&quot;) {
            log.error(&quot;❌ Role mismatch: &quot; + res.role)
            prev.setSuccessful(false)
            prev.setResponseMessage(&quot;Role is not Admin. Got: &quot; + res.role)
            return
        }
        log.info(&quot;✅ Role is Admin&quot;)
        
        // pm.environment.set(&quot;admin_token&quot;, res.token)
        // Already done by JSON Extractor above
        // But also save it here for safety
        vars.put(&quot;admin_token&quot;, res.token)
        log.info(&quot;✅ Admin token saved&quot;)
        break

    case 400:
        log.error(&quot;❌ Status 400 - Bad Request&quot;)
        prev.setSuccessful(false)
        prev.setResponseMessage(&quot;400 - Bad Request&quot;)
        // pm.execution.setNextRequest(null) → In JMeter we stop the thread
        ctx.getThread().stop()
        break

    case 401:
        log.error(&quot;❌ Status 401 - Unauthorized&quot;)
        if (res.message != &quot;Invalid credentials&quot;) {
            log.error(&quot;Message: &quot; + res.message)
        }
        prev.setSuccessful(false)
        prev.setResponseMessage(&quot;401 - Invalid credentials&quot;)
        ctx.getThread().stop()
        break

    case 404:
        log.error(&quot;❌ Status 404 - User not found: &quot; + res.message)
        prev.setSuccessful(false)
        prev.setResponseMessage(&quot;404 - User not found&quot;)
        ctx.getThread().stop()
        break

    case 500:
        log.error(&quot;❌ Status 500 - Server error: &quot; + res.message)
        prev.setSuccessful(false)
        prev.setResponseMessage(&quot;500 - Server error&quot;)
        ctx.getThread().stop()
        break

    default:
        log.error(&quot;❌ Unexpected status code: &quot; + code)
        prev.setSuccessful(false)
        prev.setResponseMessage(&quot;Unexpected status code: &quot; + code)
        ctx.getThread().stop()
        break
}</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
