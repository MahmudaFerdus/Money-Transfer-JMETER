        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Save all local data to global(Easily accessible from one thread group to another)">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">def safePut = { key -&gt;
    def value = vars.get(key)
    if (value != null) {
        props.put(key, value)
        log.info(&quot;  ✅ &quot; + key + &quot; = &quot; + value)
    } else {
        log.warn(&quot;  ⚠️ &quot; + key + &quot; is NULL - skipping&quot;)
    }
}

// Customer 1
log.info(&quot;SAVING CUSTOMER 1 DATA:&quot;)
safePut(&quot;customer_name&quot;)
safePut(&quot;customer_email&quot;)
safePut(&quot;customer_password&quot;)
safePut(&quot;customer_phone&quot;)
safePut(&quot;customer_nid&quot;)
safePut(&quot;customer_id&quot;)
//Customer 2
log.info(&quot;SAVING CUSTOMER 2 DATA:&quot;)
safePut(&quot;customer2_name&quot;)
safePut(&quot;customer2_email&quot;)
safePut(&quot;customer2_password&quot;)
safePut(&quot;customer2_phone&quot;)
safePut(&quot;customer2_nid&quot;)
safePut(&quot;customer2_id&quot;)

// Agent
log.info(&quot;SAVING AGENT DATA:&quot;)
safePut(&quot;agent_name&quot;)
safePut(&quot;agent_email&quot;)
safePut(&quot;agent_password&quot;)
safePut(&quot;agent_phone&quot;)
safePut(&quot;agent_nid&quot;)
safePut(&quot;agent_id&quot;)

// Merchant
log.info(&quot;SAVING MERCHANT DATA:&quot;)
safePut(&quot;merchant_name&quot;)
safePut(&quot;merchant_email&quot;)
safePut(&quot;merchant_password&quot;)
safePut(&quot;merchant_phone&quot;)
safePut(&quot;merchant_nid&quot;)
safePut(&quot;merchant_id&quot;)

// Admin Token
log.info(&quot;SAVING ADMIN TOKEN:&quot;)
safePut(&quot;admin_token&quot;)

log.info(&quot;========================================&quot;)
log.info(&quot;✅ ALL DATA SAVED TO PROPERTIES&quot;)
log.info(&quot;========================================&quot;)</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
