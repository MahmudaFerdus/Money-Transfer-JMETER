          </JSONPostProcessor>
          <hashTree/>
          <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract Customer NID from Response">
            <stringProp name="JSONPostProcessor.referenceNames">customer_nid</stringProp>
            <stringProp name="JSONPostProcessor.jsonPathExprs">$.user.nid</stringProp>
