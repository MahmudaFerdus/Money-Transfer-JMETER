          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate Random Agent Data" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import com.github.javafaker.Faker
import java.security.SecureRandom

def faker = new Faker()
def random = new SecureRandom()

// Random Full Name
def name = faker.name().fullName()

// Random Email
def email = faker.internet().emailAddress()

// Random Strong Password
def password = faker.internet().password(8, 16, true, true, false)

// Unique NID (last 10 digits of timestamp + random digit for extra safety)
def nid = String.valueOf(System.currentTimeMillis()).takeRight(9) + random.nextInt(9)

// Bangladesh Mobile Prefix
def prefixes = [&quot;013&quot;, &quot;014&quot;, &quot;015&quot;, &quot;016&quot;, &quot;017&quot;, &quot;018&quot;, &quot;019&quot;]
def phone_number = prefixes[random.nextInt(prefixes.size())] + 
                   String.valueOf(random.nextInt(90000000) + 10000000)

// Optional: Agent Role (if required by API)
def role = &quot;Agent&quot;

// Set as JMeter variables
vars.put(&quot;agent_name&quot;, name)
vars.put(&quot;agent_email&quot;, email)
vars.put(&quot;agent_phone&quot;, phone_number)
vars.put(&quot;agent_nid&quot;, nid)
vars.put(&quot;agent_password&quot;, password)
vars.put(&quot;agent_role&quot;, role)

// Log for debugging
log.info(&quot;agent_name: &quot; + name)
log.info(&quot;agent_email: &quot; + email)
log.info(&quot;agent_phone: &quot; + phone_number)
log.info(&quot;agent_nid: &quot; + nid)
log.info(&quot;agent_password: &quot; + password)
log.info(&quot;agent_role: &quot; + role)</stringProp>
          </JSR223PreProcessor>
