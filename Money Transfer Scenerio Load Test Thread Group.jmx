            <stringProp name="script">import com.github.javafaker.Faker
import java.security.SecureRandom

def faker = new Faker()
def random = new SecureRandom()

// Random Full Name (truly random like Postman&apos;s $randomFullName)
def name = faker.name().fullName()

// Random Email (truly random like Postman&apos;s $randomEmail)
def email = faker.internet().emailAddress()

// Random Password (truly random like Postman&apos;s $randomPassword)
def password = faker.internet().password(8, 16, true, true, false)

// NID (last 10 digits of timestamp)
def nid = String.valueOf(System.currentTimeMillis()).takeRight(10)

// Random Phone Number
def prefixes = [&quot;013&quot;, &quot;014&quot;, &quot;015&quot;, &quot;016&quot;, &quot;017&quot;, &quot;018&quot;, &quot;019&quot;]
def phone_number = prefixes[random.nextInt(prefixes.size())] + String.valueOf(random.nextInt(90000000) + 10000000)

// Set as JMeter variables (customer2_ prefix)
vars.put(&quot;customer2_name&quot;, name)
vars.put(&quot;customer2_email&quot;, email)
vars.put(&quot;customer2_phone&quot;, phone_number)
vars.put(&quot;customer2_nid&quot;, nid)
vars.put(&quot;customer2_password&quot;, password)

// Log for debugging
log.info(&quot;customer2_name: &quot; + name)
log.info(&quot;customer2_email: &quot; + email)
log.info(&quot;customer2_phone: &quot; + phone_number)
log.info(&quot;customer2_nid: &quot; + nid)
log.info(&quot;customer2_password: &quot; + password)</stringProp>
